const messaging = firebase.messaging();

// Wannan zai riƙa nuna sanarwar kira koda app ɗin a rufe yake
messaging.onBackgroundMessage((payload) => {
  console.log('Kiran Gaggawa Ya Iso:', payload);
  
  const notificationTitle = 'Kira Daga CMchat Pro';
  const notificationOptions = {
    body: payload.data.callerName + ' yana kiran ka...',
    icon: '/icon.png', // Saka icon ɗin app ɗinka anan
    tag: 'call-notification',
    vibrate: [200, 100, 200, 100, 200, 100, 400],
    actions: [
      { action: 'accept', title: 'Dagawa' },
      { action: 'decline', title: 'Kashewa' }
    ]
  };

  self.registration.showNotification(notificationTitle, notificationOptions);
});
