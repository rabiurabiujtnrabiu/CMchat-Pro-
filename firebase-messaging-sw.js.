importScripts('https://www.gstatic.com/firebasejs/9.6.10/firebase-app-compat.js');
importScripts('https://www.gstatic.com/firebasejs/9.6.10/firebase-messaging-compat.js');

const firebaseConfig = {
    apiKey: "AIzaSyCnhd2Wo5KCeE33A50WPMbVBxkoqEzkwvY",
    authDomain: "cmchat-pro.firebaseapp.com",
    projectId: "cmchat-pro",
    storageBucket: "cmchat-pro.firebasestorage.app",
    messagingSenderId: "227572132170",
    appId: "1:227572132170:web:cc39de4627d4da01c7f9b3"
};

firebase.initializeApp(firebaseConfig);
const messaging = firebase.messaging();

messaging.onBackgroundMessage((payload) => {
  console.log('Sakon CMchat Pro Ya Iso:', payload);
  
  // Logic na tantance nau'in sanarwa (Kira ko Group Message)
  const isCall = payload.data.type === 'incoming_call';
  const isUrgent = payload.data.priority === 'high'; // Advanced Setting
  
  const notificationTitle = isCall ? 'Kiran Gaggawa Daga CMchat Pro' : payload.notification.title;
  
  const notificationOptions = {
    body: isCall ? (payload.data.callerName + ' yana kiran ka...') : payload.notification.body,
    icon: '/icon.png',
    badge: '/badge.png', // Icon karami na sama
    tag: isCall ? 'call-notification' : 'group-chat',
    // Idan kira ne na "Commander", vibration din zai yi tsayi
    vibrate: isUrgent ? [500, 110, 500, 110, 450, 110, 200, 110, 1000] : [200, 100, 200],
    data: payload.data, // Adana bayanan don amfani nan gaba
    actions: isCall ? [
      { action: 'accept', title: 'Dagawa ✅' },
      { action: 'decline', title: 'Kashewa ❌' }
    ] : [
      { action: 'open_chat', title: 'Budewa 💬' }
    ]
  };

  self.registration.showNotification(notificationTitle, notificationOptions);
});

// Logic na lokacin da aka taba Notification
self.addEventListener('notificationclick', (event) => {
  event.notification.close();
  const action = event.action;
  const data = event.notification.data;

  if (action === 'accept') {
    // Tura mutum zuwa dakin kiran bidiyo
    clients.openWindow('/video-call?room=' + data.roomId);
  } else {
    // Bude app din kawai
    clients.openWindow('/');
  }
});
